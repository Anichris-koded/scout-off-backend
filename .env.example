# Stellar / Soroban
CONTRACT_ID=
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK=testnet
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Runtime
NODE_ENV=development
PORT=4000

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
ADMIN_WALLET=

# IPFS / Pinata
PINATA_API_KEY=
PINATA_SECRET=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Platform
PLATFORM_FEE_BPS=500
LOG_LEVEL=info

# Database
DB_PATH=scout-off.db

# Feature flags
STELLAR_HEALTH_CHECK=true
JSON_PAYLOAD_LIMIT=1mb

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Webhooks
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# Cache (search cache backend — see src/services/cache.ts)
# When unset, falls back to an in-memory Map (no setup required).
# Set to enable the Redis-backed cache for multi-instance deployments,
# e.g. redis://localhost:6379 or redis://redis:6379 under docker-compose.
REDIS_URL=
PLAYER_CACHE_TTL_MS=60000
